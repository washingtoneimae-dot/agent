# AgentMarket — Environment Configuration

DOMAIN=http://localhost:80

DB_USER=agentmarket
DB_PASSWORD=change_me_in_production
JWT_SECRET=change_me_in_production

MINIO_ACCESS_KEY=agentmarket
MINIO_SECRET_KEY=change_me_in_production

# Stripe — get keys from https://dashboard.stripe.com/test/apikeys
# Create a $9/month product and copy the price ID
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_SUBSCRIPTION_PRICE_ID=price_placeholder

# AI Provider — choose one: openrouter, deepseek, or openai
AI_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-v1-...
# DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# AI_MODEL=  (optional override)

N8N_ENCRYPTION_KEY=change_me_in_production
N8N_USER_MANAGEMENT_JWT_SECRET=change_me_in_production

# Notion (for Notion integration)
# NOTION_API_KEY=ntn_...

LETSENCRYPT_EMAIL=admin@example.com
DEBUG=true
