# Openfield — Environment Configuration (VPS Deploy)
#
# Copy this to .env and fill in every value.
# NEVER commit .env to git.

# ── Domain (REQUIRED) ──────────────────────────────────────────────────────────
# Point your domain's DNS A record to your VPS IP first.
DOMAIN=yourdomain.com

# ── Database ───────────────────────────────────────────────────────────────────
DB_USER=openfield
DB_PASSWORD=generate_a_strong_password_here

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
JWT_SECRET=change_me_in_production

# ── MinIO (S3 storage) ────────────────────────────────────────────────────────
MINIO_ACCESS_KEY=openfield
MINIO_SECRET_KEY=generate_a_strong_password_here

# ── Stripe (payments) ─────────────────────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
# Without these, the app runs in demo mode (subscribe = instant).
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create a $9/mo subscription product in Stripe Dashboard:
# https://dashboard.stripe.com/products
STRIPE_SUBSCRIPTION_PRICE_ID=price_...

# ── AI Provider ───────────────────────────────────────────────────────────────
# Choose one: openrouter, deepseek, or openai
# Fill in the matching API key below.
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=sk-or-v1-...
# DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# AI_MODEL=  (optional — leave empty for defaults)

# ── Let's Encrypt ─────────────────────────────────────────────────────────────
# Used for SSL certificate registration.
LETSENCRYPT_EMAIL=admin@yourdomain.com

# ── Dev / Debug ───────────────────────────────────────────────────────────────
DEBUG=false
